# ------------------------------------------------------------
# web service (Next.js)
# ------------------------------------------------------------

# Internal base URL used by Next.js rewrites to reach the API service
# inside Docker Compose.
INTERNAL_API_ORIGIN=http://api:4000

# Number of questions requested by the frontend per quiz.
# This is public at build/runtime in the web app.
NEXT_PUBLIC_QUIZ_QUESTION_LIMIT=10


# ------------------------------------------------------------
# api service (Express)
# ------------------------------------------------------------

# API listen port inside the API container.
API_PORT=4000

# PostgreSQL connection string used by the API.
# If you change POSTGRES_* values below, update this value as well.
DATABASE_URL=postgres://quiz:quiz@db:5432/quiz_app

# Default question limit used by the API if no query param limit is sent.
QUIZ_QUESTION_LIMIT=10


# ------------------------------------------------------------
# db service (PostgreSQL)
# ------------------------------------------------------------

# Initial database user created by the postgres image.
POSTGRES_USER=quiz

# Password for POSTGRES_USER.
POSTGRES_PASSWORD=quiz

# Initial database name created by the postgres image.
POSTGRES_DB=quiz_app
